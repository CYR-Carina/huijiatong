# 惠家通 Agent 环境变量配置示例

# 复制此文件为 .env 并填写实际值

# 豆包大模型配置
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_SECRET_KEY=your_doubao_secret_key_here

# 火山引擎 ASR 配置
VOLC_ASR_API_KEY=your_volc_asr_api_key_here
VOLC_ASR_SECRET_KEY=your_volc_asr_secret_key_here

# 火山引擎 TTS 配置
VOLC_TTS_API_KEY=your_volc_tts_api_key_here
VOLC_TTS_SECRET_KEY=your_volc_tts_secret_key_here

# 服务配置
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=INFO

# 数据库配置 (可选)
DATABASE_URL=sqlite:///./huijiatong.db

# 安全配置
API_KEY=your_api_key_here
ALLOWED_ORIGINS=*

# Trae 平台配置 (如果使用 Trae 托管)
TRAE_PROJECT_ID=your_trae_project_id
TRAE_API_KEY=your_trae_api_key